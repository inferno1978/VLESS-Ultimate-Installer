"""
vless_installer/modules/tg_nets.py
───────────────────────────────────────────────────────────────────────────────
Управление подсетями Telegram: хранение, обновление из множества источников,
применение к iptables/ipset.

Источники (в порядке приоритета при обновлении):
  1. RIPE NCC Routing Information Service (stat.ripe.net) — по ASN
  2. BGPView API — публичный REST-API по ASN
  3. Встроенный hardcoded-список (fallback, всегда работает)

Поддерживаемые ASN Telegram:
  AS62041  — основной (Europe / Americas / Singapore)
  AS59930  — Americas
  AS44907  — CDN India / Singapore
  AS211157 — новый (2021), Европа / Россия
  AS42065  — исторический (109.239.140.0/24 и др., AS31500 GNM hosting)

Файл хранения: /etc/telemt/tg_nets.txt
  Формат: по одной CIDR на строку, # — комментарий.
  Обновляется командой "Обновить подсети Telegram" из меню Telemt.

Точки входа:
  get_tg_nets()               → list[str]  — загрузить (файл → fallback)
  update_tg_nets_interactive()             — интерактивное обновление с выводом
  tg_nets_status_line()       → str        — строка статуса для меню
───────────────────────────────────────────────────────────────────────────────
"""

from __future__ import annotations

import json
import re
import sys
import time
import urllib.request
from datetime import datetime
from pathlib import Path
from typing import Optional

# ══════════════════════════════════════════════════════════════════════════════
#  ЦВЕТА (автодетект TTY)
# ══════════════════════════════════════════════════════════════════════════════
def _detect_colors() -> dict:
    if sys.stdout.isatty():
        return dict(
            RED='\033[0;31m', GREEN='\033[0;32m', YELLOW='\033[1;33m',
            CYAN='\033[0;36m', BOLD='\033[1m', DIM='\033[2m',
            WHITE='\033[1;37m', NC='\033[0m',
        )
    return {k: '' for k in ('RED', 'GREEN', 'YELLOW', 'CYAN', 'BOLD', 'DIM', 'WHITE', 'NC')}

_C = _detect_colors()
RED, GREEN, YELLOW, CYAN, BOLD, DIM, WHITE, NC = (
    _C['RED'], _C['GREEN'], _C['YELLOW'], _C['CYAN'],
    _C['BOLD'], _C['DIM'], _C['WHITE'], _C['NC'],
)

# ══════════════════════════════════════════════════════════════════════════════
#  КОНСТАНТЫ
# ══════════════════════════════════════════════════════════════════════════════
NETS_FILE   = Path("/etc/telemt/tg_nets.txt")
WARN_DAYS   = 30    # предупреждение об устаревании
STALE_DAYS  = 90    # критически устарело

# ASN Telegram — все активные
TG_ASNS_V4 = [62041, 59930, 44907, 211157, 42065]
TG_ASNS_V6 = [62041, 59930, 44907, 211157]  # AS42065 не анонсирует IPv6

# ══════════════════════════════════════════════════════════════════════════════
#  ВСТРОЕННЫЙ СПИСОК (hardcoded fallback, май 2026)
#  Используется если все источники недоступны.
#  109.239.140.0/24 добавлен — AS42065/TELEGRAM-NETWORK (Nikolai Durov / GNM hosting)
# ══════════════════════════════════════════════════════════════════════════════
_BUILTIN_NETS: list[str] = [
    # ── AS62041 — основной блок (Europe / Americas) ────────────────────────
    "91.108.4.0/22",      # DC1/DC3 Miami
    "91.108.8.0/22",      # DC2/DC4 Amsterdam
    "91.108.56.0/22",     # DC5 Singapore
    "95.161.64.0/20",     # российский диапазон (4096 адресов)
    "149.154.160.0/22",   # DC Amsterdam — реальный BGP-анонс /22
    "149.154.162.0/23",   # DC Amsterdam — суб-анонс внутри /22
    "149.154.164.0/22",   # DC2/DC4 Amsterdam
    "149.154.166.0/23",   # DC — суб-анонс внутри /22
    # ── AS59930 — Americas ────────────────────────────────────────────────
    "91.108.12.0/22",     # DC
    "149.154.172.0/22",   # DC
    # ── AS44907 — CDN India / Singapore ──────────────────────────────────
    "91.108.20.0/22",     # CDN (India/SG)
    # ── AS211157 — новый ASN (2021), Европа / Россия ─────────────────────
    "91.105.192.0/23",    # 512 адресов
    "185.76.151.0/24",    # 256 адресов
    # ── AS42065 / AS31500 GNM — исторические диапазоны Telegram ──────────
    "109.239.140.0/24",   # TELEGRAM-NETWORK (Nikolai Durov / GNM hosting, NL)
    # ── IPv6 ──────────────────────────────────────────────────────────────
    "2001:67c:4e8::/48",   # AS62041
    "2001:b28:f23d::/48",  # AS59930
    "2001:b28:f23c::/48",  # AS44907
    "2a0a:f280:203::/48",  # AS211157
]

# ══════════════════════════════════════════════════════════════════════════════
#  ВАЛИДАЦИЯ CIDR
# ══════════════════════════════════════════════════════════════════════════════
_RE_V4 = re.compile(
    r'^(\d{1,3}\.){3}\d{1,3}/([0-9]|[12]\d|3[012])$'
)
_RE_V6 = re.compile(
    r'^[0-9a-fA-F:]+/(\d{1,3})$'
)

def _valid_cidr(cidr: str) -> bool:
    cidr = cidr.strip()
    if not cidr:
        return False
    return bool(_RE_V4.match(cidr) or _RE_V6.match(cidr))

def _dedup_sorted(nets: list[str]) -> list[str]:
    seen: set = set()
    result = []
    for n in nets:
        n = n.strip()
        if n and n not in seen:
            seen.add(n)
            result.append(n)
    # IPv4 первыми, затем IPv6
    v4 = sorted([n for n in result if ':' not in n])
    v6 = sorted([n for n in result if ':' in n])
    return v4 + v6

# ══════════════════════════════════════════════════════════════════════════════
#  ФАЙЛОВОЕ ХРАНИЛИЩЕ
# ══════════════════════════════════════════════════════════════════════════════
def _load_from_file() -> Optional[list[str]]:
    """Читает NETS_FILE. Возвращает None если файл не существует или пустой."""
    if not NETS_FILE.exists():
        return None
    lines = NETS_FILE.read_text(encoding="utf-8").splitlines()
    nets  = [l.split("#")[0].strip() for l in lines]
    nets  = [n for n in nets if _valid_cidr(n)]
    return nets if nets else None


def _save_to_file(nets: list[str], source_info: str = "") -> None:
    """Сохраняет список подсетей в NETS_FILE с заголовком."""
    NETS_FILE.parent.mkdir(parents=True, exist_ok=True)
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    lines = [
        f"# Telegram IP networks — {len(nets)} entries",
        f"# Updated: {now}",
        f"# Source:  {source_info or 'unknown'}",
        "#",
        "# IPv4",
    ]
    v4 = [n for n in nets if ':' not in n]
    v6 = [n for n in nets if ':' in n]
    lines += v4
    if v6:
        lines += ["", "# IPv6"]
        lines += v6
    lines.append("")
    NETS_FILE.write_text("\n".join(lines), encoding="utf-8")
    NETS_FILE.chmod(0o644)


def _file_age_days() -> Optional[int]:
    """Возвращает возраст файла в днях или None."""
    if not NETS_FILE.exists():
        return None
    return int((time.time() - NETS_FILE.stat().st_mtime) / 86400)

# ══════════════════════════════════════════════════════════════════════════════
#  ИСТОЧНИК 1: RIPE NCC Routing Information Service
# ══════════════════════════════════════════════════════════════════════════════
def _fetch_ripe_asn(asn: int, timeout: int = 15) -> list[str]:
    """
    Запрашивает список префиксов ASN через RIPE stat.ripe.net.
    Возвращает список CIDR или [] при ошибке.
    """
    url = f"https://stat.ripe.net/data/announced-prefixes/data.json?resource=AS{asn}&starttime=latest"
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "VLESS-Ultimate-Installer/4.11"})
        with urllib.request.urlopen(req, timeout=timeout) as r:
            data = json.loads(r.read())
        prefixes = data.get("data", {}).get("prefixes", [])
        return [p["prefix"] for p in prefixes if _valid_cidr(p.get("prefix", ""))]
    except Exception:
        return []


def _fetch_from_ripe(asns_v4: list[int], asns_v6: list[int],
                     verbose: bool = False) -> tuple[list[str], bool]:
    """
    Обходит все ASN через RIPE stat.
    Возвращает (nets, ok_flag).
    """
    all_nets: list[str] = []
    success = False
    asns = list(set(asns_v4 + asns_v6))
    for asn in asns:
        if verbose:
            print(f"  {DIM}→ RIPE: AS{asn}...{NC}", end="", flush=True)
        nets = _fetch_ripe_asn(asn)
        if nets:
            all_nets += nets
            success = True
            if verbose:
                print(f" {GREEN}{len(nets)} префиксов{NC}")
        else:
            if verbose:
                print(f" {YELLOW}нет данных{NC}")
    return all_nets, success

# ══════════════════════════════════════════════════════════════════════════════
#  ИСТОЧНИК 2: BGPView API
# ══════════════════════════════════════════════════════════════════════════════
def _fetch_bgpview_asn(asn: int, timeout: int = 15) -> list[str]:
    """
    Запрашивает префиксы ASN через bgpview.io API (v2).
    Возвращает список CIDR или [] при ошибке.
    """
    url = f"https://api.bgpview.io/asn/{asn}/prefixes"
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "VLESS-Ultimate-Installer/4.11"})
        with urllib.request.urlopen(req, timeout=timeout) as r:
            data = json.loads(r.read())
        nets: list[str] = []
        d = data.get("data", {})
        for entry in d.get("ipv4_prefixes", []) + d.get("ipv6_prefixes", []):
            cidr = entry.get("prefix", "")
            if _valid_cidr(cidr):
                nets.append(cidr)
        return nets
    except Exception:
        return []


def _fetch_from_bgpview(asns_v4: list[int], asns_v6: list[int],
                        verbose: bool = False) -> tuple[list[str], bool]:
    all_nets: list[str] = []
    success = False
    asns = list(set(asns_v4 + asns_v6))
    for asn in asns:
        if verbose:
            print(f"  {DIM}→ BGPView: AS{asn}...{NC}", end="", flush=True)
        nets = _fetch_bgpview_asn(asn)
        if nets:
            all_nets += nets
            success = True
            if verbose:
                print(f" {GREEN}{len(nets)} префиксов{NC}")
        else:
            if verbose:
                print(f" {YELLOW}нет данных{NC}")
    return all_nets, success

# ══════════════════════════════════════════════════════════════════════════════
#  ПУБЛИЧНЫЙ API
# ══════════════════════════════════════════════════════════════════════════════
def get_tg_nets() -> list[str]:
    """
    Возвращает актуальный список подсетей Telegram.
    Порядок: файл /etc/telemt/tg_nets.txt → встроенный список.
    Никогда не возвращает пустой список.
    """
    from_file = _load_from_file()
    if from_file:
        return from_file
    return list(_BUILTIN_NETS)


def fetch_tg_nets_from_sources(verbose: bool = True) -> tuple[list[str], str]:
    """
    Запрашивает подсети из всех онлайн-источников.
    Возвращает (nets, source_description).
    При неудаче всех источников возвращает встроенный список.
    """
    # Источник 1: RIPE NCC
    if verbose:
        print(f"\n  {CYAN}Источник 1: RIPE NCC stat.ripe.net{NC}")
    nets_ripe, ok_ripe = _fetch_from_ripe(TG_ASNS_V4, TG_ASNS_V6, verbose=verbose)

    # Источник 2: BGPView
    if verbose:
        print(f"\n  {CYAN}Источник 2: BGPView API{NC}")
    nets_bgp, ok_bgp = _fetch_from_bgpview(TG_ASNS_V4, TG_ASNS_V6, verbose=verbose)

    # Объединяем
    combined = nets_ripe + nets_bgp
    if combined:
        # Убедимся что встроенные "якорные" подсети тоже присутствуют
        # (иногда источники отдают только анонсируемые прямо сейчас)
        for anchor in _BUILTIN_NETS:
            if anchor not in combined:
                combined.append(anchor)
        result = _dedup_sorted(combined)
        parts = []
        if ok_ripe:  parts.append("RIPE NCC")
        if ok_bgp:   parts.append("BGPView")
        source = " + ".join(parts) + f" + builtin anchors ({len(result)} nets)"
        return result, source

    # Оба источника недоступны → встроенный список
    if verbose:
        print(f"\n  {YELLOW}⚠  Онлайн-источники недоступны — используем встроенный список{NC}")
    return list(_BUILTIN_NETS), "builtin (offline)"


def update_tg_nets_interactive() -> list[str]:
    """
    Интерактивное обновление списка подсетей Telegram.
    Сохраняет результат в файл и возвращает итоговый список.
    """
    print()
    print(f"  {CYAN}{BOLD}Обновление списка подсетей Telegram{NC}")
    print(f"  {DIM}ASN: {', '.join('AS' + str(a) for a in TG_ASNS_V4)}{NC}")
    print()

    nets, source = fetch_tg_nets_from_sources(verbose=True)

    print()
    v4 = [n for n in nets if ':' not in n]
    v6 = [n for n in nets if ':' in n]
    print(f"  {GREEN}✓ Получено: {len(nets)} подсетей ({len(v4)} IPv4, {len(v6)} IPv6){NC}")

    _save_to_file(nets, source)
    print(f"  {GREEN}✓ Сохранено: {NETS_FILE}{NC}")

    return nets


def tg_nets_status_line() -> str:
    """
    Однострочный статус для вывода в меню.
    Пример: "Подсети TG: 17 (файл 2025-01-15, 3 дн.)"
    """
    age = _file_age_days()
    nets = get_tg_nets()
    count = len(nets)

    if age is None:
        return f"{YELLOW}Подсети TG: {count} (встроенный список, файл не создан){NC}"

    now_str = datetime.fromtimestamp(NETS_FILE.stat().st_mtime).strftime("%Y-%m-%d")
    if age >= STALE_DAYS:
        col = RED
        tag = f" — {RED}УСТАРЕЛ {age} дн.!{NC}"
    elif age >= WARN_DAYS:
        col = YELLOW
        tag = f" — {YELLOW}устарел {age} дн.{NC}"
    else:
        col = GREEN
        tag = f", {age} дн."

    return f"{col}Подсети TG: {count} ({now_str}{tag}){NC}"
